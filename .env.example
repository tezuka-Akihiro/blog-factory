# 外部ブログリポジトリのpostsフォルダへの絶対パスまたは相対パス
BLOG_SOURCE_PATH=../claudemix/content/blog/posts

# サブスクリプション仕様書（YAML）へのパス
SUBSCRIPTION_SPEC_PATH=../claudemix/app/specs/account/subscription-spec.yaml

# Cloudflare D1（wrangler が自動使用）
CLOUDFLARE_API_TOKEN=

# Cloudflare Analytics API（kpi-collect コマンド用）
# Cloudflare ダッシュボード > My Profile > API Tokens で "Zone Analytics" 権限のトークンを作成
CF_ANALYTICS_TOKEN=
# Cloudflare ダッシュボード > ドメイン選択 > 概要ページ右下の "Zone ID"
CLOUDFLARE_ZONE_ID=
