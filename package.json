{
  "name": "blog-factory",
  "version": "1.0.0",
  "description": "「技術本 2.0」を製造・メンテナンスし続ける、構造的品質の司令塔。",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "inspect": "ts-node src/commands/index.ts inspect",
    "summary": "ts-node src/commands/index.ts summary",
    "info": "ts-node src/commands/index.ts info",
    "delivery": "ts-node src/commands/index.ts delivery",
    "export": "ts-node src/commands/index.ts export",
    "update-metadata": "ts-node src/commands/index.ts update-metadata",
    "report": "ts-node src/commands/index.ts report",
    "lint": "tsc --noEmit && eslint src && npm run lint:design",
    "lint:fix": "eslint src --fix",
    "lint:design": "ts-node --transpile-only src/utils/design-lint.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tezuka-Akihiro/blog-factory.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tezuka-Akihiro/blog-factory/issues"
  },
  "homepage": "https://github.com/tezuka-Akihiro/blog-factory#readme",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "google-auth-library": "^10.6.1",
    "gray-matter": "^4.0.3",
    "wrangler": "^4.70.0"
  }
}
